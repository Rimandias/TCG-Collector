# Chave da Pokemon TCG API (https://pokemontcg.io) - opcional, aumenta o rate limit.
# NUNCA exponha essa chave no frontend. Ela só é usada aqui no backend.
POKEMONTCG_API_KEY=

# URL do projeto Supabase (Project Settings > API)
SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Chave secreta (service_role) do Supabase. NUNCA exponha essa chave no frontend.
SUPABASE_SERVICE_ROLE_KEY=troque-por-sua-service-role-key

# Porta em que o backend vai rodar
PORT=8787

# Origem(ns) do frontend permitida(s) pelo CORS - aceita uma lista separada por
# vírgulas (ex: domínio com e sem "www", já que a Vercel costuma redirecionar um
# pro outro): CLIENT_ORIGIN=https://tcgcolecionador.com.br,https://www.tcgcolecionador.com.br
CLIENT_ORIGIN=http://localhost:3000
