# URL do projeto Supabase (Project Settings > API)
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Publishable key do Supabase (segura para expor no frontend)
VITE_SUPABASE_PUBLISHABLE_KEY=troque-por-sua-publishable-key

# Opcional: aponta o proxy do dev server (vite.config.ts) para outra porta do backend
VITE_API_URL_PROXY_TARGET=http://localhost:8787
